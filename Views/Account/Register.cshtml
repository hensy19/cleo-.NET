@{
    Layout = null;
    ViewData["Title"] = "Signup";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CLEO</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/global.css" />
    <link rel="stylesheet" href="~/css/Login.css" />
    <link rel="stylesheet" href="~/css/Signup.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body style="margin: 0; padding: 0; background-color: white;">
    <div class="auth-page-v3">
        <!-- Back Navigation Icon -->
        <a asp-controller="Public" asp-action="Home" class="back-nav-v3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </a>

        <div class="auth-container-v3">
            <!-- Left: Illustration Box -->
            <div class="auth-visual-box-v3">
                <img src="~/images/signup.svg" alt="Sign Up Illustration" />
            </div>

            <!-- Right: Form Section -->
            <div class="auth-form-section-v3">
                <div class="auth-lotus-logo-v3">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10517F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L9 9H15L12 2Z"></path>
                        <path d="M12 22L15 15H9L12 22Z"></path>
                        <path d="M22 12L15 9V15L22 12Z"></path>
                        <path d="M2 12L9 15V9L2 12Z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </div>

                <div class="auth-header-v3">
                    <h1>Create Your Account</h1>
                    <p>Start your cycle tracking journey today</p>
                </div>

                <form method="post" action="/signup" class="auth-form-v3">
                    @Html.AntiForgeryToken()
                    <div class="auth-group-v3">
                        <label>Full Name</label>
                        <input type="text" name="name" placeholder="Enter your name" required />
                    </div>
                    <div class="auth-group-v3">
                        <label>Email Address</label>
                        <input type="email" name="email" placeholder="abc@example.com" required />
                    </div>
                    <div class="auth-group-v3">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="Create a password" required />
                    </div>
                    <div class="auth-group-v3">
                        <label>Confirm password</label>
                        <input type="password" name="confirmPassword" placeholder="Confirm your password" required />
                    </div>

                    <button type="submit" class="auth-btn-primary-v3">
                        Create account
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </button>
                    
                    <div class="auth-divider-v3">
                        <span>Or continue with</span>
                    </div>

                    <a asp-controller="Account" asp-action="GoogleLogin" class="auth-btn-google-v3">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" />
                        Continue with Google
                    </a>
                </form>

                @if (TempData["RegisterMessage"] != null)
                {
                    <p class="auth-status-msg-v3 error">@TempData["RegisterMessage"]</p>
                }

                <div class="auth-footer-v3">
                    <p>Already have an account? <a href="/login">Sign in</a></p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
