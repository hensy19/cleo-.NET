@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-left reveal">
        <h1>
            Rhythm. <span class="gradient-text">Insight.</span> Balance.
        </h1>
        <p>
            Track your menstrual patterns, understand phase-based changes,
            and receive personalized recommendations to support better health and well-being.
        </p>

        <div class="hero-buttons">
            <a href="#" class="btn-primary">Get Started ></a>
            <a href="#" class="btn-outline">Learn More</a>
        </div>
    </div>

    <!-- Floating SaaS Dashboard -->
    <div class="dashboard reveal">
        <div class="dashboard-header"></div>
        <div class="dashboard-chart"></div>
        <div class="dashboard-stats">
            <div class="stat"></div>
            <div class="stat"></div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features reveal">
    <h2>Everything You Need to Know About Your Cycle</h2>
    <p class="section-subtitle">
        Powerful features designed to help you understand and predict your cycle with precision.
    </p>

    <div class="features-grid">
        <div class="feature-card reveal">
            <h3>Smart Cycle Tracking</h3>
            <p>Log period dates, flow intensity, and symptoms.</p>
        </div>

        <div class="feature-card reveal">
            <h3>Predictive Insights</h3>
            <p>Accurate predictions for upcoming cycles and fertile windows.</p>
        </div>

        <div class="feature-card reveal">
            <h3>Health Analytics</h3>
            <p>Identify trends and patterns in your menstrual health.</p>
        </div>

        <div class="feature-card reveal">
            <h3>Doctor Consultation</h3>
            <p>Secure one-to-one online consultation.</p>
        </div>

        <div class="feature-card reveal">
            <h3>Personalized Wellness</h3>
            <p>Phase-based diet and exercise recommendations.</p>
        </div>

        <div class="feature-card reveal">
            <h3>Calendar View</h3>
            <p>Visualize your cycle history with clarity.</p>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-it-works reveal">
    <h2>How CycleCircle Works</h2>

    <div class="steps">
        <div class="step reveal">
            <div class="circle">1</div>
            <h4>Create Account</h4>
        </div>

        <div class="step reveal">
            <div class="circle">2</div>
            <h4>Log Cycle</h4>
        </div>

        <div class="step reveal">
            <div class="circle">3</div>
            <h4>Get Insights</h4>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta reveal">
    <h2>Ready to Start Your Journey?</h2>
    <p>Join thousands of women who trust CycleCircle.</p>
    <a href="#" class="btn-dark">Start Tracking Now ></a>
</section>